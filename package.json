    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/oparamo/aframe-room-component/issues"
  },
  "homepage": "https://github.com/oparamo/aframe-room-component#readme",
  "devDependencies": {
    "eslint": "9.39.4",
    "neostandard": "0.13.0",
    "terser": "5.46.1",
